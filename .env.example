# ─────────────────────────────────────────────────────────────────────────────
#  home-game-servers — environment template
#  Copy to ".env" and fill in. NEVER commit the real .env (it's gitignored).
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Linux user/group the containers run as. Find yours with: id -u  /  id -g
PUID=1000
PGID=1000

# Timezone (affects in-game time logs, backup timestamps)
TZ=America/Sao_Paulo

# ── Shared admin / RCON secrets ──────────────────────────────────────────────
# RCON lets the backup script flush saves before snapshotting. Keep these
# private and bound to localhost (the compose files only expose RCON on 127.0.0.1).
RCON_PASSWORD=change-me-rcon
ADMIN_PASSWORD=change-me-admin
SERVER_PASSWORD=               # leave blank for no join password

# ── Minecraft (CurseForge modpack server) ────────────────────────────────────
# Runs a CurseForge modpack via TYPE=AUTO_CURSEFORGE. The pack decides the MC
# version + mod loader. NOTE: every player must install the SAME pack to join.
MC_MEMORY=4G                   # modpacks are hungry; 4G+ (don't exceed ~total_ram - 2G)
# Free CurseForge API key — https://console.curseforge.com → "My API Keys".
# Keys contain '$': in THIS file wrap the whole value in single quotes (no escaping):
#   CF_API_KEY='$2a$10$abcd...'
CF_API_KEY=
# Modpack to run — a CurseForge page URL or slug, e.g.:
#   MC_CF_MODPACK=https://www.curseforge.com/minecraft/modpacks/all-the-mods-10
#   MC_CF_MODPACK=all-the-mods-10
MC_CF_MODPACK=

# ── Palworld ─────────────────────────────────────────────────────────────────
PAL_SERVER_NAME=Gabriel's Palworld
PAL_PLAYERS=8
PAL_MEMORY=16G

# ── ARK: Survival Evolved ────────────────────────────────────────────────────
ARK_SESSION_NAME=Gabriel's ARK
ARK_MAP=TheIsland
ARK_MAX_PLAYERS=10
ARK_MEMORY=16G
# Comma-separated Steam Workshop mod IDs, e.g.: ARK_MODS=731604991,895711211
ARK_MODS=

# ── Offsite backups (rclone remote) ──────────────────────────────────────────
# Name of the rclone remote you configured (see scripts/host-setup.sh).
# Backblaze B2 (10GB free) or Cloudflare R2 (10GB free, no egress fees) recommended.
# Leave blank to keep backups local-only.
RCLONE_REMOTE=                 # e.g. b2:gabriel-game-backups
BACKUP_KEEP_LOCAL=7            # how many local snapshots to retain per game
BACKUP_KEEP_REMOTE=14          # how many offsite snapshots to retain per game
