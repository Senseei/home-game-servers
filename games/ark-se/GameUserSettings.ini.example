; ─────────────────────────────────────────────────────────────────────────────
;  ARK gameplay config — SAMPLE (GameUserSettings.ini → [ServerSettings])
;
;  These are the gameplay keys this server runs. To apply, with the server
;  STOPPED, MERGE these into the live file (do NOT overwrite it — the live file
;  also holds passwords / RCON / session that the image manages):
;    games/ark-se/server/server/ShooterGame/Saved/Config/LinuxServer/GameUserSettings.ini
;  then start the server. See games/ark-se/README.md for the full workflow.
; ─────────────────────────────────────────────────────────────────────────────
[ServerSettings]
; Difficulty — max wild dino level 300 (10 × 30)
DifficultyOffset=1.0
OverrideOfficialDifficulty=10.0

ServerPVE=True
AllowFlyerSpeedLeveling=True

; Building QoL
bAllowPlatformSaddleMultiFloors=True       ; multiple floors on platform saddles
bDisableStructurePlacementCollision=True   ; place structures overlapping / no-clip into terrain

; Rates
XPMultiplier=2.0
TamingSpeedMultiplier=10.0
PlayerCharacterHealthRecoveryMultiplier=3.0    ; player HP regen ×3
DinoCharacterHealthRecoveryMultiplier=3.0      ; tamed dino HP regen ×3

; Loot quality — greatly boosted
SupplyCrateLootQualityMultiplier=4.0
FishingLootQualityMultiplier=4.0

; Breeding — fast hatch/grow, tuned for EASY 100% imprints
MatingIntervalMultiplier=0.05
EggHatchSpeedMultiplier=50.0
BabyMatureSpeedMultiplier=30.0
BabyFoodConsumptionSpeedMultiplier=0.3
BabyCuddleIntervalMultiplier=0.1
BabyImprintAmountMultiplier=3.0
BabyCuddleLoseImprintQualitySpeedMultiplier=0.0   ; missed cuddles don't lose imprint quality
