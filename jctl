#!/usr/bin/env bash
# jctl — the Java launcher. No args → interactive TUI; args → scriptable CLI.
# (The bash tool stays ./ctl; this is its Java successor while they coexist.)
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
jar="$root/launcher/target/ctl.jar"

if [[ ! -f "$jar" ]]; then
  echo "jctl: building launcher (first run)…" >&2
  ( cd "$root/launcher" && mvn -q -B package -DskipTests )
fi

cd "$root"               # so the tool finds games/ + scripts/ regardless of CWD
exec java -jar "$jar" "$@"
